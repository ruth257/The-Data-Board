# GEMINI_API_KEY: Required for Gemini AI API calls.
# DATA_BOARD_KEY: Custom editable key for the application.
# For security on static sites (GitHub Pages), the app now uses a 
# "Secure AI Setup" UI that saves the key to the browser's local storage.
# This prevents the key from being leaked in the public JS bundle.
GEMINI_API_KEY=""
DATA_BOARD_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
